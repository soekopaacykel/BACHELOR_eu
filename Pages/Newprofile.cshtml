    // DK search system variables
    let allCompetencies = [];
    let selectedDKCompetencies = [];

    function initializeDKSearch() {
        console.log('Initializing DK search...');
        // Build searchable competencies list from existing categories (same as VN)
        const categories = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Categories));
        console.log('Raw categories data:', categories);
        allCompetencies = [];
        
        if (!categories || !Array.isArray(categories)) {
            console.error('Categories data is invalid:', categories);
            return;
        }
        
        categories.forEach(category => {
            console.log('Processing category:', category.CategoryName);
            
            // Add the category itself as a searchable competency
            allCompetencies.push({
                name: category.CategoryName,
                category: category.CategoryName,
                subCategory: 'General',
                type: 'category'
            });
            console.log('  Added category as competency:', category.CategoryName);
            
            if (category.SubCategories && Array.isArray(category.SubCategories)) {
                category.SubCategories.forEach(subCategory => {
                    console.log('  Processing subcategory:', subCategory.SubCategoryName);
                    
                    // Add the subcategory itself as a searchable competency
                    allCompetencies.push({
                        name: subCategory.SubCategoryName,
                        category: category.CategoryName,
                        subCategory: subCategory.SubCategoryName,
                        type: 'subcategory'
                    });
                    console.log('    Added subcategory as competency:', subCategory.SubCategoryName);
                    
                    // If this subcategory has specific competencies (like Programming), add those too
                    if (subCategory.Competencies && Array.isArray(subCategory.Competencies)) {
                        subCategory.Competencies.forEach(competency => {
                            console.log('    Adding specific competency:', competency.CompetencyName);
                            allCompetencies.push({
                                name: competency.CompetencyName,
                                category: category.CategoryName,
                                subCategory: subCategory.SubCategoryName,
                                type: 'competency'
                            });
                        });
                    }
                });
            }
        });
        
        console.log('Total competencies loaded:', allCompetencies.length);
        console.log('All competencies:', allCompetencies);
        
        // Search specifically for "Project" related competencies
        const projectCompetencies = allCompetencies.filter(comp => 
            comp.name.toLowerCase().includes('project') || comp.category.toLowerCase().includes('project')
        );
        console.log('Competencies containing "project":', projectCompetencies);
        
        setupDKSearchEvents();
    }

    function setupDKSearchEvents() {
        console.log('Setting up DK search events...');
        const searchInput = document.getElementById('competencySearchInput');
        const searchResults = document.getElementById('searchResults');
        
        if (!searchInput || !searchResults) {
            console.error('Search elements not found!', {searchInput: !!searchInput, searchResults: !!searchResults});
            return;
        }
        
        searchInput.addEventListener('input', function() {
            const query = this.value.toLowerCase().trim();
            console.log('Search query:', query);
            
            if (query.length < 2) {
                searchResults.style.display = 'none';
                return;
            }
            
            const filtered = allCompetencies.filter(comp => 
                comp.name.toLowerCase().includes(query) && 
                !selectedDKCompetencies.find(sel => sel.name === comp.name)
            );
            
            console.log('Filtered competencies:', filtered.length);
            
            if (filtered.length > 0) {
                searchResults.innerHTML = filtered.slice(0, 8).map(comp => {
                    const safeName = comp.name.replace(/'/g, '&#39;').replace(/"/g, '&quot;');
                    const safeCategory = comp.category.replace(/'/g, '&#39;').replace(/"/g, '&quot;');
                    const safeSubCategory = comp.subCategory.replace(/'/g, '&#39;').replace(/"/g, '&quot;');
                    
                    // Determine display text based on type
                    let displayText = '';
                    if (comp.type === 'category') {
                        displayText = `${comp.category}`;
                    } else if (comp.type === 'subcategory') {
                        displayText = `${comp.category} → ${comp.subCategory}`;
                    } else {
                        displayText = `${comp.category} → ${comp.subCategory}`;
                    }
                    
                    return `<div onclick="selectDKCompetency('${safeName}', '${safeCategory}', '${safeSubCategory}')" 
                              style="padding: 8px 12px; cursor: pointer; border-bottom: 1px solid #eee; background: white;">
                            <strong>${comp.name}</strong><br>
                            <small style="color: #666;">${displayText}</small>
                         </div>`;
                }).join('');
                searchResults.style.display = 'block';
                console.log('Search results displayed');
            } else {
                searchResults.style.display = 'none';
                console.log('No results found');
            }
        });
        
        // Hide results when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('#dkCompetencySearch')) {
                searchResults.style.display = 'none';
            }
        });
        
        console.log('DK search events set up successfully');
    }

    function selectDKCompetency(name, category, subCategory) {
        // Decode HTML entities back to normal characters
        const decodeName = name.replace(/&#39;/g, "'").replace(/&quot;/g, '"');
        const decodeCategory = category.replace(/&#39;/g, "'").replace(/&quot;/g, '"');
        const decodeSubCategory = subCategory.replace(/&#39;/g, "'").replace(/&quot;/g, '"');
        
        selectedDKCompetencies.push({
            name: decodeName,
            category: decodeCategory,
            subCategory: decodeSubCategory,
            level: 1
        });
        
        updateDKCompetenciesDisplay();
        updateCompetencies(); // Use existing update function
        
        // Clear search
        document.getElementById('competencySearchInput').value = '';
        document.getElementById('searchResults').style.display = 'none';
    }

    function updateDKCompetenciesDisplay() {
        const listEl = document.getElementById('selectedCompetenciesList');
        
        if (selectedDKCompetencies.length === 0) {
            listEl.innerHTML = '<p style="color: #666; font-style: italic;">No competencies selected</p>';
            return;
        }
        
        listEl.innerHTML = '<h3>Selected Competencies:</h3>' + 
            selectedDKCompetencies.map((comp, index) => 
                `<div style="border: 1px solid #ddd; border-radius: 5px; padding: 12px; margin: 8px 0; background: #f9f9f9;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                        <div>
                            <strong>${comp.name}</strong><br>
                            <small style="color: #666;">${comp.category} → ${comp.subCategory}</small>
                        </div>
                        <button onclick="removeDKCompetency(${index})" style="background: #ff4444; color: white; border: none; border-radius: 3px; padding: 4px 8px; font-size: 12px;">Remove</button>
                    </div>
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <label>Level:</label>
                        <input type="range" min="1" max="10" value="${comp.level}" 
                               onchange="updateDKCompetencyLevel(${index}, this.value)" style="flex: 1;">
                        <span style="font-weight: bold; min-width: 25px;">${comp.level}</span>
                    </div>
                </div>`
            ).join('');
    }

    function removeDKCompetency(index) {
        selectedDKCompetencies.splice(index, 1);
        updateDKCompetenciesDisplay();
        updateCompetencies();
    }

    function updateDKCompetencyLevel(index, level) {
        selectedDKCompetencies[index].level = parseInt(level);
        updateDKCompetenciesDisplay();
        updateCompetencies();
    }

    // Funktion til at hente og fylde sprogsektionerne
    function fetchAndFillLanguages() {
        fetch('/api/competencies/DK/GetLanguages')
            .then(response => response.json())
            .then(languages => {
                // Når sprogene er hentet, viser vi dem med en slider
                fillLanguagesWithSliders(languages);
            })
            .catch(error => console.error('Fejl ved hentning af Languages:', error));
    }

    // Funktion til at vise sprogene med en slider for niveau
    function fillLanguagesWithSliders(languages) {
        const languageSections = document.getElementById('languagesSections');

        // Gennemgå hvert sprog og tilføj det til sektionen
        languages.forEach(language => {
            // Dupliker skabelonen for sprogsektionen
            const newLanguageSection = document.getElementById('languageTemplate').cloneNode(true);
            newLanguageSection.style.display = 'block'; // Fjern skjulning af skabelon

            // Find og opdater checkbox og label
            const checkbox = newLanguageSection.querySelector('.language-checkbox');
            checkbox.id = "checkbox_" + language.LanguageName;
            const checkboxLabel = newLanguageSection.querySelector('label[for="checkbox_template"]');
            checkboxLabel.setAttribute('for', "checkbox_" + language.LanguageName);
            checkboxLabel.textContent = language.LanguageName; // Sæt sprogets navn som label

            // Fjern sprognavnet label fra .language-field (det er ikke nødvendigt at vise det her)
            const languageFieldLabel = newLanguageSection.querySelector('.language-field label');
            languageFieldLabel.remove();  // Fjern den ekstra label

            // Find og opdater niveau-slider
            const levelSlider = newLanguageSection.querySelector('.language-level-slider');
            levelSlider.id = "slider_" + language.LanguageName;
            levelSlider.value = 0; // Standardværdi
            levelSlider.disabled = true;  // Deaktiver slider som standard

            // Find og opdater niveauindikatoren
            const levelValue = newLanguageSection.querySelector('.level-value');
            levelValue.textContent = levelSlider.value; // Initial værdi for niveauindikator

            // Opdater værdien af slideren når der sker en ændring
            levelSlider.addEventListener('input', function () {
                levelValue.textContent = levelSlider.value;
            });

            // Event listener til checkbox for at aktivere/deaktivere slideren
            checkbox.addEventListener('change', function () {
                levelSlider.disabled = !checkbox.checked;  // Aktiver slider når checkbox er checked
            });

            // Tilføj den nye sprogsektion til containeren
            languageSections.appendChild(newLanguageSection);
        });
    }

    // Kald funktionen når DOM er klar
    document.addEventListener('DOMContentLoaded', function () {
        // Hent og fyld sprogene, når siden indlæses
        fetchAndFillLanguages();
    });



    function fetchAndFillDropdowns() {
        // Hent Degrees fra API
        fetch('/api/competencies/DK/GetDegrees')
            .then(response => response.json())
            .then(degrees => {
                fillDropdown('degreeSelect', degrees);
            })
            .catch(error => console.error('Fejl ved hentning af Degrees:', error));

        // Hent Fields og Engineering Fields fra API
        fetch('/api/competencies/DK/GetFields')
            .then(response => response.json())
            .then(fields => {
                fetch('/api/competencies/DK/GetEngineeringFields')
                    .then(response => response.json())
                    .then(engineeringFields => {
                        // Kombiner Fields og Engineering Fields i én liste
                        const allFields = fields.concat(engineeringFields);
                        fillDropdown('fieldSelect', allFields);
                    })
                    .catch(error => console.error('Fejl ved hentning af Engineering Fields:', error));
            })
            .catch(error => console.error('Fejl ved hentning af Fields:', error));

        // Funktion til at fylde dropdowns
        function fillDropdown(selectClass, data) {
            var selectElements = document.querySelectorAll(`.${selectClass}`);

            selectElements.forEach(selectElement => {
                // "Please choose"-option
                if (!selectElement.querySelector('option[value=""]')) {
                    const defaultOption = document.createElement("option");
                    defaultOption.value = "";
                    defaultOption.textContent = "Select your " + selectElement.name;
                    selectElement.prepend(defaultOption); // Brug prepend for at sætte den som første option
                }

                data.forEach(function (item) {
                    var option = document.createElement("option");
                    option.value = item;
                    option.textContent = item;
                    selectElement.appendChild(option);
                });
            });
        }
    }


    // Kald funktionen for at fylde dropdowns første gang, når DOM'en er klar
    document.addEventListener("DOMContentLoaded", fetchAndFillDropdowns);

    function toggleEndDate(currentCheckbox) {
        // Find the closest date container that contains this checkbox
        const dateContainer = currentCheckbox.closest('.date-container');
        const endDateInput = dateContainer.querySelector('input[name="endDate"]');

        if (currentCheckbox.checked) {
            endDateInput.disabled = true;  // Deaktiverer 'End Date', når 'Current' er tjekket
            endDateInput.value = "";  // Fjerner værdien, hvis checkboxen er tjekket
        } else {
            endDateInput.disabled = false;  // Aktiverer 'End Date', når 'Current' ikke er tjekket
        }
    }


    function addEduSection() {
        // Find containeren, hvor sektionerne skal indsættes
        const educationSections = document.getElementById("educationSections");

        // Opret en wrapper til den nye sektion
        const newEduSection = document.createElement("div");
        newEduSection.classList.add("education-section");

        // Klon de nødvendige elementer
        const degreeFieldContainer = document.querySelector(".degree-field-container").cloneNode(true);
        const institutionField = document.querySelector(".institution-field").cloneNode(true);
        const dateContainer = document.querySelector(".date-container").cloneNode(true);

        // Giv de nye dropdowns unikke id'er og klasser
        const degreeSelects = degreeFieldContainer.querySelectorAll("select");
        degreeSelects.forEach((select, index) => {
            select.classList.add(`new-degreeSelect-${new Date().getTime()}-${index}`);
        });

        const fieldSelects = degreeFieldContainer.querySelectorAll(".fieldSelect");
        fieldSelects.forEach((select, index) => {
            select.classList.add(`new-fieldSelect-${new Date().getTime()}-${index}`);
        });

        // Ryd input-felter
        degreeSelects.forEach(select => select.selectedIndex = 0); // Ryd dropdown
        institutionField.querySelector("input").value = ""; // Ryd institution
        dateContainer.querySelectorAll("input").forEach(input => input.value = ""); // Ryd date input

        // Håndter "current"-feltet (checkbox) korrekt
        const currentCheckbox = dateContainer.querySelector("input[type='checkbox']");
        if (currentCheckbox) {
            // Reset "current" checkbox til falsk
            currentCheckbox.checked = false;

            // Lyt til ændringer på "current"-checkboxen og opdater andre input-felter
            currentCheckbox.addEventListener("change", function () {
                const startDateInput = dateContainer.querySelector("input[name='startDate']");
                const endDateInput = dateContainer.querySelector("input[name='endDate']");

                if (currentCheckbox.checked) {
                    // Hvis "current" er valgt, deaktivér slutdato-input
                    endDateInput.disabled = true;
                    endDateInput.value = ""; // Fjern slutdatoen
                } else {
                    // Ellers aktiver slutdato-input
                    endDateInput.disabled = false;
                }
            });
        }

        // Opret en fjern-knap til sektionen
        const removeButton = document.createElement("button");
        removeButton.textContent = "✕";
        removeButton.classList.add("remove-education-btn");
        removeButton.onclick = function () {
            newEduSection.remove();
        };

        // Tilføj elementerne til den nye sektion
        newEduSection.appendChild(degreeFieldContainer);
        newEduSection.appendChild(institutionField);
        newEduSection.appendChild(dateContainer);
        newEduSection.appendChild(removeButton);

        // Tilføj den nye sektion til den eksisterende container
        educationSections.appendChild(newEduSection);

        // Kald fetchAndFillDropdowns igen for at fylde de nye dropdowns
        fetchAndFillDropdowns();
    }


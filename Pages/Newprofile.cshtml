                function fixIncompleteDate(dateStr) {
                    if (!dateStr) return "";
                    const parts = dateStr.split('-');
                    // If we have just the year
                    if (parts.length === 1) return `${parts[0]}-${defaultValue}-${defaultValue}`;
                    // If we have year and month
                    if (parts.length === 2) return `${parts[0]}-${parts[1]}-${defaultValue}`;
                    return dateStr;

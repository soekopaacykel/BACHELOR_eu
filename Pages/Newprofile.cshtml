    function showErrorModal(message, errors = []) {
        const modal = document.getElementById('errorModal');
        const errorMessage = document.getElementById('errorMessage');
        const errorList = document.getElementById('errorList');
        
        errorMessage.textContent = message;
        errorList.innerHTML = '';
        
        if (errors.length > 0) {
            errors.forEach(error => {
                const li = document.createElement('li');
                li.textContent = error;
                errorList.appendChild(li);
            });
        }
        
        modal.style.display = 'block';
    }

    function closeErrorModal() {
        document.getElementById('errorModal').style.display = 'none';
    }

    // Region selection modal functions
    function showRegionSelectionModal() {
        const modal = document.getElementById('regionModal');
        modal.style.display = 'block';
    }

    function confirmRegionSelection() {
        const selectedRegion = document.querySelector('input[name="regionChoice"]:checked');
        
        if (!selectedRegion) {
            alert('Please select a region before confirming.');
            return;
        }

        const region = selectedRegion.value;
        
        // Update the session region element
        const sessionRegionElement = document.querySelector('[data-session-region]');
        if (sessionRegionElement) {
            sessionRegionElement.setAttribute('data-session-region', region);
        }
        
        // Store the selected region locally as backup
        localStorage.setItem('selectedRegion', region);
        
        // Set region in session via AJAX call
        fetch('/api/user/set-region', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ region: region })
        })
        .then(response => response.json())
        .then(data => {
            // Close the modal
            document.getElementById('regionModal').style.display = 'none';
            console.log('Region set to:', region);
            
            // Automatically retry form submission
            console.log('Retrying form submission with region:', region);
            submitApplication(); // Retry the submission automatically
        })
        .catch(error => {
            console.error('Error setting region:', error);
            // Close modal anyway and use localStorage fallback
            document.getElementById('regionModal').style.display = 'none';
            console.log('Retrying form submission with local region:', region);
            submitApplication(); // Still retry even if API call failed
        });
    }


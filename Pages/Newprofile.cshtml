    function toggleCompetencies(subCategoryName, sectionId, isChecked) {
        console.log(`toggleCompetencies called for ${subCategoryName} in section ${sectionId}, isChecked: ${isChecked}`);

        var categories = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Categories));
        var category = categories.find(item => item.SubCategories.some(subCat => subCat.SubCategoryName === subCategoryName));
        var subCategory = category.SubCategories.find(subCat => subCat.SubCategoryName === subCategoryName);

        var competencyContainer = document.getElementById("competency_" + subCategoryName + "_" + sectionId);
        console.log(`Competency container found: ${competencyContainer !== null}`);

        if (isChecked) {
            console.log(`Showing competencies for ${subCategoryName}`);

            if (!competencyContainer.hasChildNodes()) {
                console.log(`Creating competency elements for ${subCategoryName}`);

                subCategory.Competencies.forEach(function (competency) {
                    console.log(`Creating UI for competency: ${competency.CompetencyName}`);

                    // Create a container for each competency
                    var competencyDiv = document.createElement("div");
                    competencyDiv.classList.add("competence-container");

                    // Create checkbox with a VERY CLEAR name
                    var checkbox = document.createElement("input");
                    checkbox.type = "checkbox";
                    checkbox.id = competency.CompetencyName + "_" + sectionId;
                    checkbox.name = "competency";  // Simple name
                    checkbox.value = competency.CompetencyName;
                    checkbox.classList.add("competency-checkbox");
                    checkbox.dataset.competencyName = competency.CompetencyName;  // Add data attribute for easier selection

                    // Create label
                    var label = document.createElement("label");
                    label.setAttribute("for", competency.CompetencyName + "_" + sectionId);
                    label.textContent = competency.CompetencyName;
                    label.classList.add("competency-label");

                    // Create slider
                    var slider = document.createElement("input");
                    slider.type = "range";
                    slider.id = "slider_" + competency.CompetencyName + "_" + sectionId;
                    slider.name = "competencyLevel";
                    slider.min = "0";
                    slider.max = "10";
                    slider.value = "0";
                    slider.classList.add("competence-slider");
                    slider.disabled = true;  // Disable slider by default

                    // Create span to show slider value
                    var span = document.createElement("span");
                    span.id = "level_" + competency.CompetencyName + "_" + sectionId;
                    span.textContent = slider.value;
                    span.classList.add("competency-level-span");

                    // Add input event on slider
                    slider.oninput = function () {
                        span.textContent = slider.value;
                        updateCompetencies();  // Update when slider value changes
                    };

                    // Add explicit event listener to checkbox
                    checkbox.onclick = function () {
                        console.log(`Competency checkbox clicked: ${competency.CompetencyName}, checked: ${this.checked}`);
                        slider.disabled = !this.checked;
                        updateCompetencies();  // Update when checkbox state changes
                    };

                    // Add elements to competencyDiv
                    competencyDiv.appendChild(checkbox);
                    competencyDiv.appendChild(label);
                    competencyDiv.appendChild(slider);
                    competencyDiv.appendChild(span);

                    // Add competencyDiv to the parent container
                    competencyContainer.appendChild(competencyDiv);
                });
            }
            competencyContainer.style.display = "block";
        } else {
            console.log(`Hiding competencies for ${subCategoryName}`);
            competencyContainer.style.display = "none";
        }

        // Call updateCompetencies after toggling
        console.log('Calling updateCompetencies from toggleCompetencies');
        updateCompetencies();
    }


    function updateCompetencies() {
        const competenciesList = [];
        console.log("Starting updateCompetencies function...");

        // Check if DK system is active
        const dkSection = document.getElementById('dkCompetencySearch');
        const isDKActive = dkSection && dkSection.style.display !== 'none';
        
        if (isDKActive && selectedDKCompetencies && selectedDKCompetencies.length > 0) {
            // Process DK competencies - group them into the same format as VN
            const dkGrouped = {};
            
            selectedDKCompetencies.forEach(comp => {
                if (!dkGrouped[comp.category]) {
                    dkGrouped[comp.category] = {
                        CategoryName: comp.category,
                        CategoryLevel: comp.level,
                        SubCategories: {}
                    };
                }
                
                if (!dkGrouped[comp.category].SubCategories[comp.subCategory]) {
                    dkGrouped[comp.category].SubCategories[comp.subCategory] = {
                        SubCategoryName: comp.subCategory,
                        SubCategoryLevel: comp.level,
                        Competencies: []
                    };
                }
                
                dkGrouped[comp.category].SubCategories[comp.subCategory].Competencies.push({
                    CompetencyName: comp.name,
                    CompetencyLevel: comp.level
                });
                
                // Update category level to max of its competencies
                dkGrouped[comp.category].CategoryLevel = Math.max(
                    dkGrouped[comp.category].CategoryLevel, comp.level
                );
                dkGrouped[comp.category].SubCategories[comp.subCategory].SubCategoryLevel = Math.max(
                    dkGrouped[comp.category].SubCategories[comp.subCategory].SubCategoryLevel, comp.level
                );
            });
            
            // Convert grouped data to array format
            Object.values(dkGrouped).forEach(category => {
                competenciesList.push({
                    CategoryName: category.CategoryName,
                    CategoryLevel: category.CategoryLevel,
                    SubCategories: Object.values(category.SubCategories)
                });
            });
            
            console.log("Processed DK competencies:", competenciesList);
        } else {
            // Process VN hierarchy competencies (original logic)
            document.querySelectorAll("[id^='categorySelect_']").forEach(categorySelect => {
            const sectionId = categorySelect.id.split("_").pop();
            const selectedCategory = categorySelect.value;
            console.log(`Processing section ${sectionId}, category: ${selectedCategory}`);

            if (selectedCategory) {
                // Get the category level
                const categorySlider = document.querySelector(`#categorySliderDiv_${sectionId} input[type="range"]`);
                const categoryLevel = categorySlider ? parseInt(categorySlider.value) : 0;
                console.log(`Category level: ${categoryLevel}`);

                // Create category object
                const categoryObj = {
                    CategoryName: selectedCategory,
                    CategoryLevel: categoryLevel,
                    SubCategories: []
                };

                // Find all subcategory containers in this section
                const subCategoryContainers = document.querySelectorAll(`#subCategoryDiv_${sectionId} .subCategoryContainer`);
                console.log(`Found ${subCategoryContainers.length} subcategory containers`);

                subCategoryContainers.forEach(container => {
                    const subCheckbox = container.querySelector('input[type="checkbox"]');

                    if (subCheckbox && subCheckbox.checked) {
                        const subCategoryName = subCheckbox.value;
                        console.log(`Processing subcategory: ${subCategoryName}`);

                        const subCategorySlider = container.querySelector('input[type="range"]');
                        const subCategoryLevel = subCategorySlider ? parseInt(subCategorySlider.value) : 0;

                        // Create subcategory object
                        const subCategoryObj = {
                            SubCategoryName: subCategoryName,
                            SubCategoryLevel: subCategoryLevel,
                            Competencies: []
                        };

                        // Find competency container
                        const competencyContainer = document.getElementById(`competency_${subCategoryName}_${sectionId}`);
                        console.log(`Competency container found: ${competencyContainer !== null}`);

                        if (competencyContainer) {
                            // Log what's inside the competency container
                            console.log(`Competency container HTML: ${competencyContainer.innerHTML}`);

                            // Find all competency checkboxes that are checked
                            const checkedCompetencyBoxes = competencyContainer.querySelectorAll('input[type="checkbox"]:checked');
                            console.log(`Found ${checkedCompetencyBoxes.length} checked competency checkboxes`);

                            checkedCompetencyBoxes.forEach(competencyCheckbox => {
                                const competencyName = competencyCheckbox.value;
                                console.log(`Found checked competency: ${competencyName}`);

                                const competencySlider = document.getElementById(`slider_${competencyName}_${sectionId}`);
                                const competencyLevel = competencySlider ? parseInt(competencySlider.value) : 0;

                                // Add competency to subcategory
                                subCategoryObj.Competencies.push({
                                    CompetencyName: competencyName,
                                    CompetencyLevel: competencyLevel
                                });
                            });
                        }

                        // Add subcategory to category
                        categoryObj.SubCategories.push(subCategoryObj);
                    }
                });

                // Add category to competenciesList
                competenciesList.push(categoryObj);
            }
            });
        } // End VN processing

        console.log("Final competencies list:", competenciesList);

        // Convert to JSON string
        const competenciesJson = JSON.stringify(competenciesList);

        // UPDATE THE HIDDEN INPUT FIELD
        const hiddenField = document.getElementById("competenciesInput");
        if (hiddenField) {
            hiddenField.value = competenciesJson;
            console.log("Hidden field updated:", hiddenField.value);
        } else {
            console.error("Error: The hidden input field 'competenciesInput' was not found.");
        }

        return competenciesJson;
    }


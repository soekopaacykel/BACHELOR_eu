    // Add real-time validation on field blur for better UX
    document.addEventListener('DOMContentLoaded', function() {
        const requiredFields = ['firstName', 'lastName', 'email', 'phone', 'address', 'city', 'country'];
        
        requiredFields.forEach(fieldId => {
            const field = document.getElementById(fieldId);
            if (field) {
                field.addEventListener('blur', function() {
                    if (this.classList.contains('field-error') && this.value.trim()) {
                        this.classList.remove('field-error');
                    }
                });
                
                field.addEventListener('input', function() {
                    if (this.classList.contains('field-error') && this.value.trim()) {
                        this.classList.remove('field-error');
                    }
                });
            }
        });
        
        // Special validation for email field
        const emailField = document.getElementById('email');
        if (emailField) {
            emailField.addEventListener('blur', function() {
                if (this.value && this.checkValidity()) {
                    this.classList.remove('field-error');
                }
            });
        }
    });

    function validateForm() {
        clearAllFieldErrors();
        const errors = [];
        
        // Required field validations
        const requiredFields = [
            { id: 'firstName', label: 'First Name' },
            { id: 'lastName', label: 'Last Name' },
            { id: 'email', label: 'Email' },
            { id: 'phone', label: 'Phone' },
            { id: 'address', label: 'Address' },
            { id: 'city', label: 'City' },
            { id: 'country', label: 'Country' }
        ];
        
        requiredFields.forEach(field => {
            const element = document.getElementById(field.id);
            if (!element || !element.value.trim()) {
                errors.push(`${field.label} is required`);
                highlightFieldError(field.id);
            }
        });
        
        // Email validation
        const emailElement = document.getElementById('email');
        const email = emailElement?.value;
        if (email && !emailElement.checkValidity()) {
            errors.push('Please enter a valid email address');
            highlightFieldError('email');
        }
        
        // Competency validation - check for checked competencies with level 0
        const competencyErrors = validateCompetencies();
        if (competencyErrors.length > 0) {
            errors.push(...competencyErrors);
            // Highlight competencies section
            const competenciesHeading = document.getElementById('CompetenciesHeading');
            if (competenciesHeading) {
                competenciesHeading.style.color = '#ff4444';
                competenciesHeading.style.fontWeight = 'bold';
            }
        }
        
        return errors;
    }
    
    function validateCompetencies() {
        const competencyErrors = [];
        
        // Check if DK system is active
        const dkSection = document.getElementById('dkCompetencySearch');
        const isDKActive = dkSection && dkSection.style.display !== 'none';
        
        if (isDKActive) {
            // For DK system, check selectedDKCompetencies array
            if (selectedDKCompetencies && selectedDKCompetencies.length > 0) {
                selectedDKCompetencies.forEach(comp => {
                    if (comp.level === 0) {
                        competencyErrors.push(`Competency "${comp.name}" is selected but has no level assigned (0). Please set a level between 1-10.`);
                    }
                });
            }
        } else {
            // For VN system, check checkboxes and their corresponding sliders
            const checkboxes = document.querySelectorAll('input[type="checkbox"][name="competencyCheck"]:checked');
            checkboxes.forEach(checkbox => {
                const competencyName = checkbox.value;
                const sectionId = checkbox.id.split('_').pop();
                const sliderId = `slider_${competencyName}_${sectionId}`;
                const slider = document.getElementById(sliderId);
                
                if (slider && parseInt(slider.value) === 0) {
                    competencyErrors.push(`Competency "${competencyName}" is checked but has no level assigned (0). Please adjust the level slider.`);
                }
            });
        }
        
        return competencyErrors;
    }

    async function submitApplication() {
        try {
            // First, validate all form fields
            const validationErrors = validateForm();
            if (validationErrors.length > 0) {
                showErrorModal('Please fix the following errors before submitting:', validationErrors);
                return;
            }
            
            // Get current region from server-side session - NO DK fallback
            let region = null;
            
            // Get region from server-side session via hidden element  
            const sessionRegionElement = document.querySelector('[data-session-region]');
            if (sessionRegionElement) {
                region = sessionRegionElement.getAttribute('data-session-region');
            }
            
            // Fallback to localStorage if session region is not available
            if (!region || (region !== 'VN' && region !== 'DK')) {
                region = localStorage.getItem('selectedRegion');
            }
            
            // Validate region before proceeding
            if (!region || (region !== 'VN' && region !== 'DK')) {
                showRegionSelectionModal();
                return;
            }
            
            console.log('Using region for submission:', region);
            let profilePictureUrl = null;

            // Make sure the competencies are updated before submission
            updateCompetencies();

            // Get the competencies JSON string from the hidden input
            const competenciesJsonString = document.getElementById("competenciesInput")?.value || "";
            let competenciesObject = [];

            // Parse the competencies JSON if it exists
            if (competenciesJsonString) {
                try {
                    competenciesObject = JSON.parse(competenciesJsonString);
                    // Ensure it's an array
                    if (!Array.isArray(competenciesObject)) {
                        console.error('Competencies data is not an array!');
                        competenciesObject = [];
                    }

                    // Validér hver eneste lille lorte ting
                    competenciesObject = competenciesObject.map(category => ({
                        CategoryName: category.CategoryName || "",
                        CategoryLevel: category.CategoryLevel || 0,
                        SubCategories: Array.isArray(category.SubCategories) ? category.SubCategories.map(sub => ({
                            SubCategoryName: sub.SubCategoryName || "",
                            SubCategoryLevel: sub.SubCategoryLevel || 0,
                            Competencies: Array.isArray(sub.Competencies) ? sub.Competencies.map(comp => ({
                                CompetencyName: comp.CompetencyName || "",
                                CompetencyLevel: comp.CompetencyLevel || 0
                            })) : []
                        })) : []
                    }));

                } catch (error) {
                    console.error('Error parsing competencies:', error);
                    competenciesObject = [];
                }
            }

            // Log the structured competencies for debugging
            console.log("Structured competencies:", JSON.stringify(competenciesObject, null, 2));
            // Initialiser educationData og previousWorkPlacesData som tomme arrays

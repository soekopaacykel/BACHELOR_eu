    var sectionCount = 0;
    function showSubCategories(sectionId) {
        var categorySelect = document.getElementById("categorySelect_" + sectionId);
        var subCategoryDiv = document.getElementById("subCategoryDiv_" + sectionId);
        var categorySliderDiv = document.getElementById("categorySliderDiv_" + sectionId);

        subCategoryDiv.innerHTML = "";
        categorySliderDiv.innerHTML = "";

        var selectedCategory = categorySelect.value;
        var categories = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Categories));

        if (selectedCategory) {
            var category = categories.find(item => item.CategoryName === selectedCategory);
            if (category) {
                // Create category slider
                var categorySliderContainer = document.createElement("div");
                categorySliderContainer.classList.add("subcategory-slider");

                var slider = document.createElement("input");
                slider.type = "range";
                slider.id = "category_slider_" + category.CategoryName + "_" + sectionId;
                slider.name = "categoryLevel_" + sectionId;
                slider.min = "0";
                slider.max = "10";
                slider.value = "0";
                slider.classList.add("subcategory-slider");


                var span = document.createElement("span");
                span.id = "category_level_" + category.CategoryName + "_" + sectionId;
                span.textContent = slider.value;

                slider.oninput = function () {
                    span.textContent = slider.value;
                };

                categorySliderContainer.appendChild(slider);
                categorySliderContainer.appendChild(span);

                categorySliderDiv.appendChild(categorySliderContainer);  // Append slider right below dropdown
                categorySliderDiv.style.display = "block";  // Ensure the slider section is visible

                category.SubCategories.forEach(function (subCategory) {
                    var subCategoryContainer = document.createElement("div");
                    subCategoryContainer.classList.add("subCategoryContainer");
                    subCategoryContainer.id = "subCategory_" + subCategory.SubCategoryName + "_" + sectionId;

                    var checkbox = document.createElement("input");
                    checkbox.type = "checkbox";
                    checkbox.id = subCategory.SubCategoryName + "_" + sectionId;
                    checkbox.name = "subCategory_" + sectionId;
                    checkbox.value = subCategory.SubCategoryName;

                    var label = document.createElement("label");
                    label.setAttribute("for", subCategory.SubCategoryName + "_" + sectionId);
                    label.textContent = subCategory.SubCategoryName;

                    var slider = document.createElement("input");
                    slider.type = "range";
                    slider.id = "subcategory_slider_" + subCategory.SubCategoryName + "_" + sectionId;
                    slider.name = "subcategoryLevel_" + sectionId;
                    slider.min = "0";
                    slider.max = "10";
                    slider.value = "0";
                    slider.classList.add("subcategory-slider");
                    slider.disabled = true;  // Disable slider by default for subcategories

                    var span = document.createElement("span");
                    span.id = "subcategory_level_" + subCategory.SubCategoryName + "_" + sectionId;
                    span.textContent = slider.value;

                    slider.oninput = function () {
                        span.textContent = slider.value;
                    };

                    checkbox.addEventListener('change', function () {
                        toggleCompetencies(subCategory.SubCategoryName, sectionId, checkbox.checked);

                        slider.disabled = !checkbox.checked;  // Enable slider when checkbox is checked, disable when unchecked
                    });

                    subCategoryContainer.appendChild(checkbox);
                    subCategoryContainer.appendChild(label);
                    subCategoryContainer.appendChild(slider);
                    subCategoryContainer.appendChild(span);

                    var competencyContainer = document.createElement("div");
                    competencyContainer.classList.add("competence-container");
                    competencyContainer.id = "competency_" + subCategory.SubCategoryName + "_" + sectionId;
                    subCategoryContainer.appendChild(competencyContainer);

                    subCategoryDiv.appendChild(subCategoryContainer);
                });
                subCategoryDiv.style.display = "block";
            }
        }
    }



    function addNewSection() {
        sectionCount++;

        var newSectionDiv = document.createElement("div");
        newSectionDiv.classList.add("section");
        newSectionDiv.id = "section_" + sectionCount;

        // Opret container for dropdown og slider
        var categoryContainer = document.createElement("div");
        categoryContainer.classList.add("category-container");
        categoryContainer.id = "categoryContainer_" + sectionCount;  // Unikt ID for sektionen
        newSectionDiv.appendChild(categoryContainer);  // Tilføj containeren til sektionen

        // Opret checkbox for slideren (sæt den som tjekket)
        var categoryCheckbox = document.createElement("input");
        categoryCheckbox.type = "checkbox";
        categoryCheckbox.classList.add("category-checkbox");
        categoryCheckbox.id = "categoryCheckbox_" + sectionCount;
        categoryCheckbox.checked = true;  // Sæt checkboxen som tjekket som standard

        // Event listener for at fjerne sektionen, når checkboxen afmærkes
        categoryCheckbox.addEventListener("change", function () {
            if (!categoryCheckbox.checked) {
                newSectionDiv.remove();  // Fjern sektionen hvis checkboxen ikke er tjekket
            }
        });

        // Opret og tilføj dropdown
        var categorySelect = document.createElement("select");
        categorySelect.id = "categorySelect_" + sectionCount;
        categorySelect.name = "category_" + sectionCount;
        categorySelect.classList.add("category-select");
        categorySelect.addEventListener("change", function () {
            showSubCategories(sectionCount);
        });

        var categories = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Categories));

        var defaultOption = document.createElement("option");
        defaultOption.value = "";
        defaultOption.textContent = "Choose a category";
        categorySelect.appendChild(defaultOption);

        categories.forEach(function (category) {
            var option = document.createElement("option");
            option.value = category.CategoryName;
            option.textContent = category.CategoryName;
            categorySelect.appendChild(option);
        });

        // Tilføj checkbox og dropdown i den ønskede rækkefølge
        categoryContainer.appendChild(categoryCheckbox);  // Tilføj checkbox før dropdown
        categoryContainer.appendChild(categorySelect);  // Tilføj dropdown til containeren


                References: referencesData,
                IsAvailable: isAvailable,
                AvailableWhen: availableWhen,
                AvailableInterval: availableInterval,
                NewApplicant: true,
            };

            console.log("Applicant data before sending:", applicant);
            console.log("JSON payload before sending:", JSON.stringify(applicant, null, 2));

            const response = await fetch(`/api/user/${region}/create-applicant`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Accept": "application/json",
                },
                body: JSON.stringify(applicant),
            });

            if (!response.ok) {
                const errorText = await response.text();
                console.error(`Server response (${response.status}):`, errorText);
                
                let errorMessage = `Server Error (${response.status})`;
                let errors = [];
                
                if (response.status === 401) {
                    errorMessage = 'Authentication Error (401)';
                    errors = [
                        'Your session has expired or you are not authorized',
                        'Please refresh the page and log in again',
                        'If you continue to see this error, contact your administrator'
                    ];
                } else if (response.status === 400) {
                    errorMessage = 'Invalid Data (400)';
                    errors = [
                        'Some of the information you provided is invalid',
                        'Please check all fields and try again'
                    ];
                    // Try to parse specific validation errors from response
                    try {
                        const errorData = JSON.parse(errorText);
                        if (errorData.errors) {
                            errors = Object.values(errorData.errors).flat();
                        }
                    } catch (e) {
                        // Keep generic errors if can't parse response
                    }
                } else if (response.status >= 500) {
                    errorMessage = 'Server Error (500)';
                    errors = [
                        'The server encountered an internal error',
                        'Please try again in a few minutes',
                        'If the problem persists, contact support'
                    ];
                } else {
                    errors = ['Please try again or contact support if the problem persists'];
                }
                
                showErrorModal(errorMessage, errors);
                return;
            }

            const responseBody = await response.json();
            console.log("Applicant created:", responseBody);
            
            // Redirect to success page with only region parameter (JWT is already in localStorage)
            window.location.href = `/SuccessPage?region=${region}`;
        } catch (error) {
            console.error("Error submitting application:", error);
            
            let errorMessage = 'An error occurred while submitting your application.';
            let specificErrors = [];
            
            // Handle specific error types
            if (error.message.includes('401')) {
                errorMessage = 'Authentication Error (401)';
                specificErrors = [
                    'Your session may have expired',
                    'Please try refreshing the page and logging in again',
                    'If the problem persists, contact your administrator'
                ];
            } else if (error.message.includes('CV upload failed')) {
                errorMessage = 'CV Upload Failed';
                specificErrors = [
                    'There was a problem uploading your CV file',
                    'Please check your internet connection',
                    'Make sure the file is a valid PDF and try again'
                ];
                highlightFieldError('cv');
            } else if (error.message.includes('Failed to upload profile picture')) {
                errorMessage = 'Profile Picture Upload Failed';
                specificErrors = [
                    'There was a problem uploading your profile picture',
                    'You can continue without a profile picture or try uploading a different image'
                ];
                highlightFieldError('profilePicture');
            } else if (error.message.includes('HTTP error')) {
                const statusMatch = error.message.match(/Status: (\d+)/);
                const status = statusMatch ? statusMatch[1] : 'Unknown';
                errorMessage = `Server Error (${status})`;
                specificErrors = [
                    'The server encountered an error while processing your request',
                    'Please try again in a few moments',
                    'If the problem persists, contact support'
                ];
            } else {
                specificErrors = [error.message || 'Please try again or contact support if the problem persists'];
            }
            
            showErrorModal(errorMessage, specificErrors);
            return;
        }
    }
    function addReferenceSection() {
        // Find containeren, hvor sektionerne skal indsættes
        const referencesSections = document.getElementById("referencesSections");

        // Opret en wrapper til den nye sektion
        const newReferenceSection = document.createElement("div");
        newReferenceSection.classList.add("reference-section");

        // Klon de nødvendige elementer
        const referenceNameField = document.querySelector(".reference-name").parentElement.cloneNode(true);
        const referenceCompanyField = document.querySelector(".reference-company").parentElement.cloneNode(true);
        const referencePhoneField = document.querySelector(".reference-phone").parentElement.cloneNode(true);
        const referenceEmailField = document.querySelector(".reference-email").parentElement.cloneNode(true);

        // Ryd input-felter
        referenceNameField.querySelector("input").value = ""; // Ryd navn
        referenceCompanyField.querySelector("input").value = ""; // Ryd virksomhed
        referencePhoneField.querySelector("input").value = ""; // Ryd telefon
        referenceEmailField.querySelector("input").value = ""; // Ryd email

        // Opret en fjern-knap til sektionen
        const removeButton = document.createElement("button");
        removeButton.textContent = "✕";
        removeButton.classList.add("remove-reference-btn");
        removeButton.onclick = function () {
            newReferenceSection.remove();
        };

        // Tilføj elementerne til den nye sektion
        newReferenceSection.appendChild(referenceNameField);
        newReferenceSection.appendChild(referenceCompanyField);
        newReferenceSection.appendChild(referencePhoneField);
        newReferenceSection.appendChild(referenceEmailField);
        newReferenceSection.appendChild(removeButton);

        // Tilføj den nye sektion til den eksisterende container
        referencesSections.appendChild(newReferenceSection);
    }

    // Event listener for knappen "Add Reference"
    document.getElementById("addReferenceSection").addEventListener("click", addReferenceSection);


    // JavaScript til at vise tooltip, når du hoverer over alle hjælp-ikonerne
    document.querySelectorAll('.help-container').forEach(function (container) {
        // Når musen er over et hjælpelogo
        container.addEventListener('mouseover', function () {
            var tooltip = this.querySelector('.tooltip');
            tooltip.style.visibility = 'visible';
            tooltip.style.opacity = 1;
        });

        // Når musen forlader hjælpelogoet
        container.addEventListener('mouseout', function () {
            var tooltip = this.querySelector('.tooltip');
            tooltip.style.visibility = 'hidden';
            tooltip.style.opacity = 0;
        });
    });

    // Function to initialize the page with the first section
    function initializePage() {
        // Add the first section
        addNewSection();
    }

    // Run initialization when the DOM is fully loaded
    document.addEventListener("DOMContentLoaded", function () {
        initializePage();
    });

    // Add JS to clear one field if the other is set (date/interval):
document.addEventListener("DOMContentLoaded", function () {
    const availableWhenInput = document.getElementById("availableWhen");
    const availableIntervalInput = document.getElementById("availableInterval");
    if (availableWhenInput && availableIntervalInput) {
        availableWhenInput.addEventListener("input", function () {
            if (this.value) availableIntervalInput.value = "";
        });
        availableIntervalInput.addEventListener("change", function () {
            if (this.value) availableWhenInput.value = "";
        });
    }
});

// Helper to get JWT token from cookies
function getJwtTokenFromCookie() {
    const match = document.cookie.match(/(?:^|; )jwt_token=([^;]*)/);
    return match ? decodeURIComponent(match[1]) : null;
}

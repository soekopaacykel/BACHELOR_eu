@page
@model CVAPI.Pages.IndexModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="css/UI/Index.css" />
    <link rel="stylesheet" href="~/CSS/alert.css" />
    <link href="https://fonts.googleapis.com/css2?family=Helvetica+Neue:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        /* Body Style */
        body {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            background: linear-gradient(45deg, #00534C, #00855A); /* Gradient baggrund */
            
            font-family: 'Helvetica Neue', sans-serif;
        }

        .vexalogo {
            margin-top: -50px;
        }

        /* Form Style */
        .form-signin {
            width: 100%;
            max-width: 500px; /* Større formular */
            padding: 40px;
            background: #fff;
            border-radius: 20px; /* Større runding på hjørnerne */
            box-shadow: 0 15px 25px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background-color: #F6F6F6; /* White background */
        }

        .form-signin:hover {
            transform: scale(1.02);
        }

        /* Header Style */
        .form-signin h2 {
            text-align: center;
            font-size: 1.5rem; /* Større overskrift */
            color: Black;
            font-family: 'Helvetica Neue', sans-serif;
            font-weight: 400; /* Bold style */
            margin-top: -8px; /* Mindre afstand til billedet */
        }

        /* Input Field Style */
        .form-control {
            width: 80%;
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-size: 1.1rem;
            transition: border-color 0.3s ease;
            font-family: 'Helvetica Neue', sans-serif;
            font-weight: 300; /* Light style */
        }

        .form-control:focus {
            border-color: #00855A;
            outline: none;
            box-shadow: 0 0 8px rgba(0, 133, 90, 0.5); /* Grøn fokusfarve */
        }

        /* Button Style */
        .btn-primary {
            width: 50%;
            padding: 15px;
            background-color: #00534C; /* Flaskegrøn knap */
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 1.2rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
            font-family: 'Helvetica Neue', sans-serif;
            font-weight: 400; /* Regular style */
        }

        .btn-primary:hover {
            background-color: #00855A;
        }

        .btn-primary:active {
            background-color: #006A4E;
        }
    </style>
</head>
<body>
    <!-- Alert Modal -->
    <div id="alertModal" class="alert-modal">
        <div class="alert-modal-content">
            <span class="close-modal" onclick="closeAlertModal()">&times;</span>
            <div class="alert-modal-header" id="alertHeader">Login Error</div>
            <div class="alert-modal-message" id="alertMessage"></div>
            <div class="alert-modal-buttons">
                <button type="button" class="alert-modal-button" id="alertButton" onclick="closeAlertModal()">OK</button>
            </div>
        </div>
    </div>
    <main>
        <form class="form-signin" method="post" onsubmit="redirectToConsultants(); return false;">
            <center><img src="~/Images/BEPALogo.png" width="200"><br /><br />
            <center><img src="~/Images/VEXALogo.png" width="70" class="vexalogo"><br /><br />
            
            <!-- Region Selector -->
            <div id="regionSelectorContainer" style="margin-bottom: 15px; width: 100%;"></div>
            
            <input type="text" id="email" name="Email" class="form-control" placeholder="Email" required />
            <input type="password" id="password" name="Password" class="form-control" placeholder="Password" required />
            <button type="submit" class="btn-primary">Login</button>
        </form>
    </main>
    <script src="~/JS/regionManager.js"></script>
    <script>
        // Initialize region selector
        document.addEventListener('DOMContentLoaded', function() {
            RegionManager.createRegionSelector('regionSelectorContainer', function(newRegion) {
                // Store the selected region when it changes
                RegionManager.setCurrentRegion(newRegion);
            });
        });
        
        async function redirectToConsultants() {
            const email = document.querySelector('#email').value;
            const password = document.querySelector('#password').value;
            const region = RegionManager.getCurrentRegion();

            console.log('Login attempt:', { email, region });
            console.log('Region type:', typeof region);
            console.log('Region value:', JSON.stringify(region));

            if (!region) {
                showAlert('Region Required', 'Please select a region before logging in.', 'error');
                return;
            }

            try {
                const loginUrl = `/api/user/${region}/login`;
                console.log('Login URL:', loginUrl);
                
                const response = await fetch(loginUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ email, password })
                });

                console.log('Response status:', response.status);
                console.log('Response ok:', response.ok);

                if (!response.ok) {
                    const error = await response.text();
                    console.error('Login failed:', error);
                    showAlert('Login Failed', `Login failed: ${error}`, 'error');
                    return;
                }

                const data = await response.json();
                console.log('Response data:', data);
                
                if (data.token) {
                    // Store JWT and user data in localStorage
                    localStorage.setItem('jwt_token', data.token);
                    localStorage.setItem('userRole', data.userRole);
                    localStorage.setItem('userEmail', data.email || email);
                    localStorage.setItem('userId', data.userId);
                    
                    // Store admin initials if present
                    if (data.adminInitials) {
                        localStorage.setItem('adminInitials', data.adminInitials);
                    }
                    
                    console.log('Stored in localStorage:');
                    console.log('- jwt_token:', localStorage.getItem('jwt_token') ? 'Present' : 'Missing');
                    console.log('- userRole:', localStorage.getItem('userRole'));
                    console.log('- userEmail:', localStorage.getItem('userEmail'));
                    console.log('- userId:', localStorage.getItem('userId'));
                    
                    // Redirect to consultants page
                    window.location.href = '/Consultants';
                } else {
                    console.error('No token in response:', data);
                    showAlert('Login Failed', 'Login failed: No token received', 'error');
                }
            } catch (error) {
                console.error('Error during login:', error);
                showAlert('Error', 'An error occurred during login. Please try again.', 'error');
            }
        }

        // Modal helper functions
        function showAlert(title, message, type = 'info', callback = null) {
            const modal = document.getElementById('alertModal');
            const header = document.getElementById('alertHeader');
            const messageEl = document.getElementById('alertMessage');
            const button = document.getElementById('alertButton');
            
            header.textContent = title;
            header.className = `alert-modal-header ${type}`;
            messageEl.textContent = message;
            button.className = `alert-modal-button ${type}`;
            
            modal.style.display = 'block';
            
            if (callback) {
                button.onclick = () => {
                    closeAlertModal();
                    callback();
                };
            } else {
                button.onclick = closeAlertModal;
            }
        }

        function closeAlertModal() {
            document.getElementById('alertModal').style.display = 'none';
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const alertModal = document.getElementById('alertModal');
            if (event.target === alertModal) {
                closeAlertModal();
            }
        }
    </script>
</body>
</html>

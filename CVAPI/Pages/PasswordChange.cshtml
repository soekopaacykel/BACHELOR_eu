@page "/PasswordChange"
@model CVAPI.Pages.PasswordChangeModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password</title>
    <link rel="stylesheet" href="~/CSS/alert.css" />
    <style>
        body {
            font-family: 'Helvetica Neue', sans-serif;
            background: linear-gradient(135deg, #00534C, #00855A);
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .content-container {
            background-color: white;
            width: 100%;
            max-width: 400px;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            color: #00534C;
            font-weight: 600;
        }

        .form-control {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 1rem;
        }

        .form-control:focus {
            border-color: #00855A;
            outline: none;
            box-shadow: 0 0 0 2px rgba(0, 133, 90, 0.2);
        }

        .btn-submit {
            background-color: #00855A;
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 5px;
            font-size: 1rem;
            font-weight: 600;
            width: 100%;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .btn-submit:hover {
            background-color: #00534C;
        }

        .alert {
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 20px;
        }

        .alert-danger {
            background-color: #ffe6e6;
            border: 1px solid #ff9999;
            color: #cc0000;
        }

        .alert-success {
            background-color: #e6ffe6;
            border: 1px solid #99ff99;
            color: #006600;
        }
    </style>
</head>
<body>
    <!-- Alert Modal -->
    <div id="alertModal" class="alert-modal">
        <div class="alert-modal-content">
            <span class="close-modal" onclick="closeAlertModal()">&times;</span>
            <div class="alert-modal-header" id="alertHeader">Password Change</div>
            <div class="alert-modal-message" id="alertMessage"></div>
            <div class="alert-modal-buttons">
                <button type="button" class="alert-modal-button" id="alertButton" onclick="closeAlertModal()">OK</button>
            </div>
        </div>
    </div>
    <div class="content-container">
        <h2 style="color: #00534C; margin-bottom: 30px; text-align: center;">Change Password</h2>
        
        <!-- Add user info display -->
        <div style="text-align: center; margin-bottom: 20px; color: #00534C;">
            <span>Logged in as </span>
            <span id="userEmail"></span>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        <form method="post">
            <div class="form-group">
                <label for="currentPassword">Current Password</label>
                <input type="password" id="currentPassword" name="CurrentPassword" class="form-control" required minlength="6">
            </div>

            <div class="form-group">
                <label for="newPassword">New Password</label>
                <input type="password" id="newPassword" name="NewPassword" class="form-control" required minlength="6" 
                       pattern="^(?=.*[A-Za-z])(?=.*\d)[A-Za-z\d]{6,}$" 
                       title="Password must be at least 6 characters long and contain both letters and numbers">
            </div>

            <div class="form-group">
                <label for="confirmPassword">Confirm New Password</label>
                <input type="password" id="confirmPassword" name="ConfirmPassword" class="form-control" required minlength="6">
            </div>

            <div class="form-group">
                <small class="text-muted">
                    Password requirements:
                    <ul>
                        <li>At least 6 characters long</li>
                        <li>Must contain both letters and numbers</li>
                    </ul>
                </small>
            </div>

            <button type="submit" class="btn-submit">Change Password</button>
        </form>
    </div>
    <script src="/js/auth.js"></script>
    <script>
        // Helper to get a cookie value by name
        function getCookie(name) {
            const match = document.cookie.match(new RegExp('(?:^|; )' + name.replace(/([.$?*|{}()\[\]\\\/\+^])/g, '\\$1') + '=([^;]*)'));
            return match ? decodeURIComponent(match[1]) : undefined;
        }
        // DEBUG flag for troubleshooting
        const DEBUG = true;
        document.addEventListener('DOMContentLoaded', async () => {
            if (DEBUG) console.debug('[DEBUG] PasswordChange page script loaded');
            // Get JWT from localStorage
            const token = localStorage.getItem('jwt_token');
            if (DEBUG) console.debug('[DEBUG] jwt_token from localStorage:', token);
            if (!token) {
                if (DEBUG) console.debug('[DEBUG] No jwt_token found, redirecting to login');
                window.location.href = '/';
                return;
            }
            let userId;
            let userEmail = localStorage.getItem('userEmail');
            if (DEBUG) console.debug('[DEBUG] user_email from localStorage:', userEmail);
            try {
                const payload = JSON.parse(atob(token.split('.')[1]));
                if (DEBUG) console.debug('[DEBUG] Decoded JWT payload:', payload);
                userId = payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier'];
                // Try to get email from localStorage, then from token
                const emailToDisplay = userEmail || 
                    payload.email || 
                    payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress'] ||
                    'Email not found';
                if (DEBUG) console.debug('[DEBUG] Email to display:', emailToDisplay);
                document.getElementById('userEmail').textContent = emailToDisplay;
            } catch (error) {
                console.error('[DEBUG] Error decoding token:', error);
            }
            document.querySelector('form').addEventListener('submit', async function(e) {
                e.preventDefault();
                
                // Client-side validation
                const currentPassword = document.getElementById('currentPassword').value;
                const newPassword = document.getElementById('newPassword').value;
                const confirmPassword = document.getElementById('confirmPassword').value;
                
                if (!currentPassword) {
                    showAlert('Validation Error', 'Please enter your current password', 'error');
                    return;
                }
                
                if (!newPassword) {
                    showAlert('Validation Error', 'Please enter a new password', 'error');
                    return;
                }
                
                if (newPassword !== confirmPassword) {
                    showAlert('Validation Error', 'New password and confirm password do not match', 'error');
                    return;
                }
                
                if (newPassword.length < 6) {
                    showAlert('Validation Error', 'Password must be at least 6 characters long', 'error');
                    return;
                }
                
                if (currentPassword === newPassword) {
                    showAlert('Validation Error', 'New password must be different from current password', 'error');
                    return;
                }
                
                try {
                    const response = await fetch('/api/user/DK/update-password', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': `Bearer ${token}`
                        },
                        body: JSON.stringify({
                            userId: userId,
                            currentPassword: document.getElementById('currentPassword').value,
                            newPassword: document.getElementById('newPassword').value
                        })
                    });
                    const result = await response.text();
                    if (DEBUG) console.debug('[DEBUG] Password change response:', response.status, result);
                    if (response.ok) {
                        showAlert('Success', 'Password changed successfully', 'success', () => {
                            // Redirect to home or login after success
                            window.location.href = '/';
                        });
                    } else {
                        try {
                            const error = JSON.parse(result);
                            showAlert('Error', error.message || 'Failed to change password', 'error');
                        } catch {
                            showAlert('Error', result || 'Failed to change password', 'error');
                        }
                    }
                } catch (error) {
                    console.error('[DEBUG] Error:', error);
                    showAlert('Error', 'An error occurred while changing the password', 'error');
                }
            });
        });

        // Modal helper functions
        function showAlert(title, message, type = 'info', callback = null) {
            const modal = document.getElementById('alertModal');
            const header = document.getElementById('alertHeader');
            const messageEl = document.getElementById('alertMessage');
            const button = document.getElementById('alertButton');
            
            header.textContent = title;
            header.className = `alert-modal-header ${type}`;
            messageEl.textContent = message;
            button.className = `alert-modal-button ${type}`;
            
            modal.style.display = 'block';
            
            if (callback) {
                button.onclick = () => {
                    closeAlertModal();
                    callback();
                };
            } else {
                button.onclick = closeAlertModal;
            }
        }

        function closeAlertModal() {
            document.getElementById('alertModal').style.display = 'none';
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const alertModal = document.getElementById('alertModal');
            if (event.target === alertModal) {
                closeAlertModal();
            }
        }
    </script>
</body>
</html>

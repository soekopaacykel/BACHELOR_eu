        document.querySelectorAll('.category-slider').forEach(slider => {
            slider.addEventListener('input', function() {
                const categoryName = this.id.replace('cat_slider_', '');
                const levelSpan = document.getElementById(`cat_level_${categoryName}`);
                if (levelSpan) {
                    levelSpan.textContent = this.value;
                }
            });
        });

        document.querySelectorAll('.subcategory-slider').forEach(slider => {
            slider.addEventListener('input', function() {
                const subCategoryName = this.id.replace('sub_slider_', '');
                const levelSpan = document.getElementById(`sub_level_${subCategoryName}`);
                if (levelSpan) {
                    levelSpan.textContent = this.value;
                }
            });
        });

        document.querySelectorAll('.competency-slider').forEach(slider => {
            slider.addEventListener('input', function() {
                const competencyName = this.id.replace('comp_slider_', '');
                const levelSpan = document.getElementById(`comp_level_${competencyName}`);
                if (levelSpan) {
                    levelSpan.textContent = this.value;
                }
            });
        });
        
        // Initialize existing competencies
        existingCompetencies.forEach(category => {
            const categoryCheckbox = document.getElementById(`cat_${category.CategoryName}`);
            const categorySlider = document.getElementById(`cat_slider_${category.CategoryName}`);
            
            if (categoryCheckbox && categorySlider) {
                categoryCheckbox.checked = true;
                categorySlider.disabled = false;
                categorySlider.value = category.CategoryLevel || 0;
                document.getElementById(`cat_level_${category.CategoryName}`).textContent = category.CategoryLevel || 0;
                toggleCategory(categoryCheckbox);
                
                category.SubCategories.forEach(subCategory => {
                    const subCheckbox = document.getElementById(`sub_${subCategory.SubCategoryName}`);
                    const subSlider = document.getElementById(`sub_slider_${subCategory.SubCategoryName}`);
                    
                    if (subCheckbox && subSlider) {
                        subCheckbox.checked = true;
                        subSlider.disabled = false;
                        subSlider.value = subCategory.SubCategoryLevel || 0;
                        document.getElementById(`sub_level_${subCategory.SubCategoryName}`).textContent = subCategory.SubCategoryLevel || 0;
                        toggleSubCategory(subCheckbox);
                        
                        subCategory.Competencies.forEach(comp => {
                            const compCheckbox = document.getElementById(`comp_${comp.CompetencyName}`);
                            const compSlider = document.getElementById(`comp_slider_${comp.CompetencyName}`);
                            
                            if (compCheckbox && compSlider) {
                                compCheckbox.checked = true;
                                compSlider.disabled = false;
                                compSlider.value = comp.CompetencyLevel || 0;
                                document.getElementById(`comp_level_${comp.CompetencyName}`).textContent = comp.CompetencyLevel || 0;
                            }
                        });
                    }
                });
            }
        });
    }

    function toggleCategory(checkbox) {
        const categoryName = checkbox.dataset.category;
        const subcategoriesContainer = document.getElementById(`subcategories_${categoryName}`);
        const categorySlider = document.getElementById(`cat_slider_${categoryName}`);
        
        if (subcategoriesContainer) {
            subcategoriesContainer.style.display = checkbox.checked ? 'block' : 'none';
            categorySlider.disabled = !checkbox.checked;
            
            if (!checkbox.checked) {
                // Uncheck all subcategories when category is unchecked
                subcategoriesContainer.querySelectorAll('.subcategory-checkbox').forEach(subCheckbox => {
                    subCheckbox.checked = false;
                    toggleSubCategory(subCheckbox);

    document.addEventListener('DOMContentLoaded', function() {
        const deleteBtn = document.getElementById('deleteProfileBtn');
        if (deleteBtn) {
            deleteBtn.addEventListener('click', async function() {
                // Get userId from URL
                const pathParts = window.location.pathname.split('/');
                const userId = pathParts[pathParts.length - 1];
                
                if (!userId) {
                    showAlert('Error', 'UserId could not be determined.', 'error');
                    return;
                }
                
                showConfirm(
                    'Delete Profile', 
                    'Are you sure you want to delete this profile? This action cannot be undone.',
                    'danger',
                    async () => {
                        // Get JWT token from localStorage using the same function as everywhere else
                        const jwtToken = getJwtTokenFromCookie();
                        if (!jwtToken) {
                            showAlert('Authentication Error', 'Authorization token is missing. Please log in again.', 'error');
                            return;
                        }
                        
                        try {
                            const response = await fetch(`/api/user/${REGION}/soft-delete`, {
                                method: 'POST',
                                headers: {
                                    'Authorization': `Bearer ${jwtToken}`,
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({ userId })
                            });
                            if (response.ok) {
                                showAlert('Success', 'Profile deleted successfully.', 'success', () => {
                                    window.location.href = '/applicants';
                                });
                            } else {
                                const error = await response.text();
                                showAlert('Delete Failed', `Failed to delete profile: ${error}`, 'error');
                            }
                        } catch (err) {
                            showAlert('Error', 'An error occurred. Please try again.', 'error');
                        }
                    }
                );
            });
        }
    });


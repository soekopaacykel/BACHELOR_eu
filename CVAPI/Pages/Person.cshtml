    // Add handler for job experience form submission
    document.querySelector('form[asp-page-handler="UpdateJobExperience"]').addEventListener('submit', function(event) {
        event.preventDefault();
        
        // Validate work experience data
        const validationErrors = validateWorkExperience();
        if (validationErrors.length > 0) {
            showErrorModal('Please fix the following work experience errors:', validationErrors);
            return;
        }
        
        const jobData = {
            userId: '@Model.Consultant.UserId',
            jobExperience: []
        };
        
        // Collect all job items
        document.querySelectorAll('.job-edit-item').forEach(item => {
            const startDateValue = item.querySelector('input[name$=".StartDate"]').value;
            const endDateValue = item.querySelector('input[name$=".EndDate"]').value;
            
            // Validate required fields before adding
            const position = item.querySelector('input[name$=".Position"]').value.trim();
            const company = item.querySelector('input[name$=".Company"]').value.trim();
            
            if (!position || !company || !startDateValue) {
                // Skip invalid entries - validation will catch this
                return;
            }
            
            jobData.jobExperience.push({
                id: parseInt(item.querySelector('input[name$=".Id"]').value),
                position: position,
                company: company,
                description: item.querySelector('textarea[name$=".Description"]').value,
                startDate: new Date(startDateValue),
                endDate: endDateValue ? new Date(endDateValue) : null
            });
        });


    </div>
    <script>
        // Confirm modal callback variable
        let confirmCallback = null;
        
        // Get region from localStorage
        const REGION = localStorage.getItem('selectedRegion');
        console.log('[DEBUG] Region set to:', REGION);
        
        // Helper function to check if region is available
        function isRegionAvailable() {
            if (!REGION) {
                console.error('[ERROR] No region selected. Please select a region first.');
                showAlert('Region Required', 'Please select a region first.', 'error');
                return false;
            }
            return true;
        }
        
        if (typeof DEBUG === 'undefined' || DEBUG) {
        console.debug("[DEBUG] Person.cshtml script loaded!");
        // User email display is now handled by auth.js, but add backup
        document.addEventListener('DOMContentLoaded', function() {
            // Backup email display if auth.js didn't work
            setTimeout(() => {
                const userEmail = localStorage.getItem('userEmail');
                const userEmailElement = document.getElementById('userEmail');
                console.debug('[DEBUG] Backup email display check:', {
                    userEmail: userEmail,
                    element: !!userEmailElement,
                    currentText: userEmailElement?.textContent
                });
                
                if (userEmailElement && userEmail && !userEmailElement.textContent) {
                    userEmailElement.textContent = userEmail;
                    console.debug('[DEBUG] Applied backup email display:', userEmail);
                }
            }, 100);
            // Always attach click handler for password change redirect
            var userInfo = document.getElementById('userInfoContainer');
            if (userInfo) {
                userInfo.style.cursor = 'pointer';
                userInfo.addEventListener('click', function() {
                    setTimeout(function() {
                        window.location.href = '/PasswordChange';
                    }, 200); // 200ms delay to allow cookies to propagate
                });
                console.debug('[DEBUG] userInfoContainer click handler attached');
            } else {
                console.debug('[DEBUG] userInfoContainer element not found');
            }
        });
    }
    document.getElementById('headerEditForm')?.addEventListener('submit', async function(event) {
        event.preventDefault();
        
        let profilePictureUrl = null;
        
        const availabilityStatus = document.getElementById('AvailabilityStatus').value;
        const headerData = {
            userId: this.querySelector('input[name="userId"]').value,
            firstName: document.getElementById('FirstName').value,
            lastName: document.getElementById('LastName').value,
            userRole: parseInt(document.getElementById('UserRole').value),
            summary: document.getElementById('Summary').value,
            isAvailable: availabilityStatus === 'available',
            availableInterval: availabilityStatus === 'interval' ? parseInt(document.getElementById('AvailableInterval').value) : null,
            availableWhen: availabilityStatus === 'date' ? document.getElementById('AvailableWhen').value : null,
            bepaStatus: document.getElementById('BepaStatus').checked,
            confirmedStatus: document.getElementById('ConfirmedStatus').checked,
            profilePictureUrl: profilePictureUrl // Include the new profile picture URL if uploaded
        };

        // Send the updated header info to the server
        fetch(`/api/user/${REGION}/update-header`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${getJwtTokenFromCookie()}`
            },
            body: JSON.stringify(headerData)
        })
        .then(response => {
            if (!response.ok) throw new Error('Failed to update header information');
            location.reload();
        })
        .catch(error => {
            console.error('Error:', error);
            showAlert('Error', 'An error occurred. Please try again.', 'error');
        });
    });

    let engineeringFields = [];
    fetch('/api/competencies/GetEngineeringFields')
        .then(response => response.json())
        .then(fields => {
            engineeringFields = fields;
            // If you need to populate dropdowns or use the fields immediately, do it here
        })
        .catch(error => {
            console.error('Failed to load engineering fields:', error);
        });

    document.addEventListener("DOMContentLoaded", function () {
        const form = document.querySelector('form[asp-page-handler="SaveNoteAsync"]');
        if (form) {
            form.addEventListener('submit', function (event) {
                event.preventDefault();
                const formData = new FormData(form);
                // Get JWT token from cookies
                const jwtToken = getJwtTokenFromCookie();
                console.log('[DEBUG] Retrieved JWT Token:', jwtToken); // Log the token for debugging
                if (!jwtToken) {
                    showAlert('Authentication Error', 'Authorization token is missing. Please log in again.', 'error');
                    return;
                }
                // Convert form data to JSON and include UserId explicitly
                const requestData = Object.fromEntries(formData.entries());
                // Accept both UserId and userId for compatibility
                const userId = requestData.UserId || requestData.userId;
                if (!userId) {
                    console.error('[ERROR] UserId is missing in the form data.');
                    showAlert('Error', 'UserId is missing. Please refresh the page and try again.', 'error');
                    return;
                }
                requestData.UserId = userId; // Ensure correct property for backend
                console.log('[DEBUG] Request Data:', requestData); // Log the request data

                // Get current region from REGION constant (no fallback to maintain region management)
                const region = REGION;
                const apiUrl = `/api/user/${region}/save-private-note`;
                fetch(apiUrl, {
                    method: 'POST',
                    headers: {

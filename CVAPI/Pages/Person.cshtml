    // Confirm Modal Functions
    function showConfirm(title, message, type = 'default', onConfirm = null) {
        const modal = document.getElementById('confirmModal');
        const header = document.getElementById('confirmHeader');
        const messageDiv = document.getElementById('confirmMessage');
        const confirmButton = document.getElementById('confirmButton');
        
        header.textContent = title;
        messageDiv.textContent = message;
        
        // Set button style based on type
        confirmButton.className = 'confirm-modal-button confirm';
        if (type === 'danger') {
            confirmButton.classList.add('danger');
        }
        
        // Store the callback function
        confirmCallback = onConfirm;
        
        modal.style.display = 'block';
    }

    function closeConfirmModal() {
        document.getElementById('confirmModal').style.display = 'none';
        confirmCallback = null;
    }

    function confirmAction() {
        if (confirmCallback && typeof confirmCallback === 'function') {
            confirmCallback();
        }
        closeConfirmModal();
    }

    // Close modal when clicking outside of it
    window.onclick = function(event) {
        const alertModal = document.getElementById('alertModal');
        const confirmModal = document.getElementById('confirmModal');
        const errorModal = document.getElementById('errorModal');
        
        if (event.target === alertModal) {
            closeAlertModal();
        }
        if (event.target === confirmModal) {
            closeConfirmModal();
        }
        if (event.target === errorModal) {
            closeErrorModal();
        }
    }


    function validateCompetencies() {
        const competencyErrors = [];
        console.log('Running competency validation...');
        
        // Check all checked competency checkboxes and their levels
        document.querySelectorAll('.competency-checkbox:checked').forEach(compCheckbox => {
            const competencyName = compCheckbox.dataset.competency;
            const competencyLevel = parseInt(document.getElementById(`comp_slider_${competencyName}`).value);
            
            console.log(`Checking competency: ${competencyName}, level: ${competencyLevel}`);
            
            if (competencyLevel === 0) {
                competencyErrors.push(`Competency "${competencyName}" is checked but has no level assigned (0). Please adjust the level slider.`);
            }
        });
        
        console.log(`Found ${competencyErrors.length} competency validation errors`);
        return competencyErrors;
    }

    // Handle form submission
    document.querySelector('form[asp-page-handler="UpdateCompetencies"]').addEventListener('submit', function(event) {
        event.preventDefault();
        console.log('Competency form submitted, running validation...');
        
        // Validate competencies first
        const competencyErrors = validateCompetencies();
        if (competencyErrors.length > 0) {
            console.log('Validation errors found:', competencyErrors);
            showAlert('Competency Validation Error', competencyErrors.join('\n\n'), 'error');
            return;
        }
        
        console.log('Validation passed, proceeding with form submission...');
        
        const competencyData = {
            userId: '@Model.Consultant.UserId',
            competencies: []
        };
        
        document.querySelectorAll('.category-checkbox:checked').forEach(categoryCheckbox => {
            const categoryName = categoryCheckbox.dataset.category;
            const categoryLevel = parseInt(document.getElementById(`cat_slider_${categoryName}`).value);
            
            const category = {
                categoryName: categoryName,      // Changed from name to categoryName
                categoryLevel: categoryLevel,    // Changed from level to categoryLevel
                subCategories: []               // Changed from subCategories to match C# model
            };
            
            const subcategoriesContainer = document.getElementById(`subcategories_${categoryName}`);
            if (subcategoriesContainer) {
                subcategoriesContainer.querySelectorAll('.subcategory-checkbox:checked').forEach(subCheckbox => {
                    const subCategoryName = subCheckbox.dataset.subcategory;
                    const subCategoryLevel = parseInt(document.getElementById(`sub_slider_${subCategoryName}`).value);
                    
                    const subCategory = {
                        subCategoryName: subCategoryName,        // Changed from name to subCategoryName
                        subCategoryLevel: subCategoryLevel,      // Changed from level to subCategoryLevel
                        competencies: []
                    };
                    
                    const competenciesContainer = document.getElementById(`competencies_${subCategoryName}`);
                    if (competenciesContainer) {
                        competenciesContainer.querySelectorAll('.competency-checkbox:checked').forEach(compCheckbox => {
                            const competencyName = compCheckbox.dataset.competency;
                            const competencyLevel = parseInt(document.getElementById(`comp_slider_${competencyName}`).value);
                            
                            // Only add competencies with level > 0 (validation should have caught this already)
                            if (competencyLevel > 0) {
                                subCategory.competencies.push({
                                    competencyName: competencyName,    // Changed from name to competencyName
                                    competencyLevel: competencyLevel   // Changed from level to competencyLevel
                                });
                            }
                        });
                    }
                    
                    category.subCategories.push(subCategory);
                });
            }
            
            competencyData.competencies.push(category);
        });

        console.log('Sending competency data:', competencyData);
        
        const jwtToken = getJwtTokenFromCookie();
        if (!jwtToken) {
            showAlert('Authentication Error', 'Authorization token is missing. Please log in again.', 'error');
            return;
        }
        
        fetch(`/api/user/${REGION}/update-competencies`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${jwtToken}`
            },
            body: JSON.stringify(competencyData)
        })
        .then(response => {
            if (!response.ok) {
                return response.text().then(text => {
                    throw new Error(text || 'Failed to update competencies');
                });
            }
            location.reload();
        })
        .catch(error => {
            console.error('Error updating competencies:', error);
            showAlert('Update Failed', 'Failed to update competencies. Please try again.', 'error');
        });
    });


    // Function to set the rating when stars are clicked
    function setRating(rating) {
        console.log(`Setting rating to: ${rating}`);
        
        // Only update PrivateRating stars, not TechRating stars
        const stars = document.querySelectorAll('#rating-stars-container .consultant-star-icon');

        // Update visual appearance of stars
        stars.forEach((star, index) => {
            if (index < rating) {
                star.classList.remove('consultant-star-empty');
                star.classList.add('consultant-star-filled');
            } else {
                star.classList.remove('consultant-star-filled');
                star.classList.add('consultant-star-empty');
            }
        });

        // Get the user ID from the URL
        const pathParts = window.location.pathname.split('/');
        const userId = pathParts[pathParts.length - 1];

        // Get JWT token from cookies
        const jwtToken = getJwtTokenFromCookie();
        if (!jwtToken) {
            showAlert('Authentication Error', 'Authorization token is missing. Please log in again.', 'error');
            return;
        }

        // Send the updated rating to the server
        fetch(`/api/user/${REGION}/update-rating`, {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${jwtToken}`,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                userId: userId,
                rating: rating,
                type: 'private'
            })
        })
        .then(response => {
            if (response.ok) {
                console.log('Rating updated successfully');
            } else {
                response.text().then(error => {
                    console.error(`Failed to update rating: ${error}`);
                    showAlert('Update Failed', `Failed to update rating: ${error}`, 'error');
                });
            }
        })
        .catch(error => {
            console.error(`Network error: ${error}`);
            showAlert('Error', 'An error occurred. Please try again.', 'error');
        });
    }

    // Function to set the TechRating when stars are clicked
    function setTechRating(rating) {
        // Get all tech rating star icons
        const stars = document.querySelectorAll('#tech-rating-stars-container .tech-rating-star');
        stars.forEach((star, index) => {
            if (index < rating) {
                star.classList.add('consultant-star-filled');
                star.classList.remove('consultant-star-empty');
            } else {
                star.classList.remove('consultant-star-filled');

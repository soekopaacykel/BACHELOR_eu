    function validateReferences() {
        clearAllFieldErrors();
        const errors = [];
        
        document.querySelectorAll('.reference-edit-item').forEach((section, index) => {
            const name = section.querySelector('input[name$=".Name"]');
            const position = section.querySelector('input[name$=".Position"]');
            const company = section.querySelector('input[name$=".Company"]');
            const email = section.querySelector('input[name$=".Email"]');
            
            if (name && !name.value.trim()) {
                errors.push(`Reference ${index + 1}: Name is required`);
                name.classList.add('field-error');
            }
            
            if (position && !position.value.trim()) {
